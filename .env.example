# Copy to `.env` in this directory (gitignored), then edit if needed:
#   cp .env.example .env
#
# Used by `docker compose` for the `api` service (see docker-compose.yml).
# Values match default service names: postgres, minio.

ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8080

ConnectionStrings__DefaultConnection=Host=postgres;Port=5432;Database=Usher_mgmt;Username=postgres;Password=postgres

Jwt__SecretKey=secretkeysecretkeysecretkeysecretkeysecretkeysecretkey
Jwt__Issuer=UMS.Api
Jwt__Audience=UMS.Clients
Jwt__AccessTokenExpiryMinutes=15
Jwt__RefreshTokenExpiryDays=7

Minio__Endpoint=minio:9000
Minio__AccessKey=minioadmin
Minio__SecretKey=minioadmin
Minio__BucketName=ums-files
Minio__UseSSL=false
Minio__PublicBaseUrl=http://localhost:9000
